# ─── Database ───────────────────────────────────
POSTGRES_USER=erebys
POSTGRES_PASSWORD=erebys_secret
POSTGRES_DB=erebys
DATABASE_URL=postgresql+asyncpg://erebys:erebys_secret@postgres:5432/erebys
DATABASE_URL_SYNC=postgresql://erebys:erebys_secret@postgres:5432/erebys

# ─── Redis ──────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── JWT Auth ───────────────────────────────────
JWT_SECRET=change-me-to-a-real-secret-key-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Backend ────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
LOG_LEVEL=INFO
ENVIRONMENT=development

# ─── Celery ─────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ─── Frontend ───────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
